{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services", "destination": "/services.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/case-studies", "destination": "/case-studies.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/build", "destination": "/build.html" },
    { "source": "/build/onboarding", "destination": "/build-onboarding.html" },
    { "source": "/build/thank-you", "destination": "/build-thank-you.html" },
    { "source": "/blog/your-crm-isnt-broken", "destination": "/blog/your-crm-isnt-broken.html" },
    { "source": "/blog/the-90-day-rule", "destination": "/blog/the-90-day-rule.html" },
    { "source": "/blog/stop-automating-chaos", "destination": "/blog/stop-automating-chaos.html" },
    { "source": "/blog/what-we-look-at-before-running-ads", "destination": "/blog/what-we-look-at-before-running-ads.html" },
    { "source": "/blog/break-up-with-your-broken-systems", "destination": "/blog/break-up-with-your-broken-systems.html" },
    { "source": "/blog/5-zapier-automations", "destination": "/blog/5-zapier-automations.html" },
    { "source": "/blog/why-data-driven-marketing", "destination": "/blog/why-data-driven-marketing.html" },
    { "source": "/blog/instagram-isnt-dead", "destination": "/blog/instagram-isnt-dead.html" },
    { "source": "/blog/healthcare-ads-not-converting", "destination": "/blog/healthcare-ads-not-converting.html" },
    { "source": "/podcast", "destination": "/podcast.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/contact.js": {
      "includeFiles": "api/**"
    }
  }
}
